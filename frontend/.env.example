# =============================================================================
# Eclipse Reads — variáveis do frontend (Vite)
# =============================================================================
# Local: copie este arquivo para .env na pasta frontend e preencha.
# Vercel: Project → Settings → Environment Variables
#   - Use os MESMOS nomes (prefixo VITE_ é obrigatório).
#   - Marque Production (e Preview, se quiser builds de branch).
#   - Após criar/editar variáveis: faça um Redeploy (o Vite embute VITE_* no build).
# =============================================================================

# --- Obrigatórias (sem elas o app quebra ao carregar o cliente Supabase) ---
# URL do projeto: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Chave pública (anon / publishable): mesma tela → anon public key
# Nome no código: VITE_SUPABASE_PUBLISHABLE_KEY (não use VITE_SUPABASE_ANON_KEY)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Backends HTTP (livros + biblioteca/perfil) ---
# URLs públicas HTTPS dos serviços em produção, com CORS permitindo o domínio Vercel.
# Repositório: services/backend/books-api e services/backend/library-service

VITE_BOOKS_API_URL=https://seu-books-api.exemplo.com
VITE_LIBRARY_API_URL=https://seu-library-service.exemplo.com

# --- Opcional ---
# Se books-api e library-service estiverem atrás da MESMA origem (proxy / gateway),
# defina só VITE_API_URL; o código usa como fallback para ambos os serviços.
# VITE_API_URL=https://api.seudominio.com
