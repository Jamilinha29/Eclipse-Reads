{
  "name": "eclipse-reads",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "services/backend/auth-proxy",
    "services/backend/books-api",
    "services/backend/library-service"
  ],
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "install:frontend": "cd frontend && npm install",
    "install:backends": "npm install --prefix services/backend/auth-proxy && npm install --prefix services/backend/books-api && npm install --prefix services/backend/library-service",
    "install:all": "npm run install:frontend && npm run install:backends",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run tests/api",
    "test:auth": "vitest run tests/auth",
    "test:cadastro": "vitest run tests/cadastro",
    "test:upload": "vitest run tests/upload",
    "test:perfil": "vitest run tests/perfil",
    "test:users": "vitest run tests/users",
    "test:load:books-api": "k6 run tests/load/k6-books-api.js",
    "test:load:supabase": "k6 run tests/load/teste-carga-completo.js",
    "test:e2e": "playwright test",
    "test:one-by-one": "node scripts/run-tests-sequential.mjs",
    "test:docker": "docker-compose -f docker-compose.tests.yml up --build --abort-on-container-exit --exit-code-from tests",
    "test:docker:one-by-one": "docker-compose -f docker-compose.tests.yml run --rm tests npm run test:one-by-one",
    "test:docker:down": "docker-compose -f docker-compose.tests.yml down --remove-orphans"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.1"
  },
  "overrides": {
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "4.19.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "supertest": "^7.1.3",
    "vitest": "^1.3.1"
  }
}
