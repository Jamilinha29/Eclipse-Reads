{
  "name": "eclipse-reads",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "services/backend/auth-proxy",
    "services/backend/books-api",
    "services/backend/library-service"
  ],
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "install:frontend": "cd frontend && npm install",
    "install:backends": "npm install --prefix services/backend/auth-proxy && npm install --prefix services/backend/books-api && npm install --prefix services/backend/library-service",
    "install:all": "npm run install:frontend && npm run install:backends",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.3",
    "vitest": "^1.3.1"
  }
}
