# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment & segredos — nunca commitar valores reais
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example
**/.env
!**/.env.example

# Backends: cópias locais com chaves (o repo pode manter *só* exemplos versionados)
services/backend/envs/*.env
!services/backend/envs/*.env.example

# Build / TypeScript
*.tsbuildinfo
.next
.nuxt
.cache

# Relatórios de cobertura de testes (Vitest / v8) — regeneram com npm run test:coverage
coverage/
**/coverage/
*.lcov
.nyc_output/

# Playwright E2E — relatórios e browsers cache local
test-results/
playwright-report/
blob-report/
playwright/.cache/
