{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth"
    },
    {
      "source": "/api/books/(.*)",
      "destination": "/api/books"
    },
    {
      "source": "/api/library/(.*)",
      "destination": "/api/library"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
